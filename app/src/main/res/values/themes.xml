<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. Compose Material 3 handles theming at runtime;
         this XML theme is only required for the window background and activity launch. -->
    <style name="Theme.MoviesApp" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
