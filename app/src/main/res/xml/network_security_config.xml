<?xml version="1.0" encoding="utf-8"?>
<!--
    Network security config — selectively allows cleartext HTTP for
    localhost and 10.0.2.2 (the Android emulator's alias for the host
    machine's localhost) while keeping all other traffic HTTPS‑only.

    Production builds default to `usesCleartextTraffic="false"` via the
    manifest, which this config **overrides only for the explicit
    localhost domains** below — every other host still requires TLS.

    If you point the app at a different local server (e.g. a LAN IP
    during physical‑device testing), add that IP here.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
</network-security-config>
